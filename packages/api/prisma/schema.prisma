generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  firstName  String
  lastName   String?
  createdAt  DateTime @default(now())
  orders     Order[]
}

model Admin {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  firstName  String
  createdAt  DateTime @default(now())
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  emoji    String?
  services Service[]
}

model Service {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  prices      Price[]
  orders      Order[]
}

model Price {
  id         Int     @id @default(autoincrement())
  serviceId  Int
  service    Service @relation(fields: [serviceId], references: [id])
  duration   String  // "1 месяц", "3 месяца", "1 год"
  basePrice  Float
  commission Float
  total      Float
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  serviceId   Int
  service     Service     @relation(fields: [serviceId], references: [id])
  duration    String
  totalPrice  Float
  status      OrderStatus @default(NEW)
  notes       String?
  adminNotes  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrderStatus {
  NEW
  PROCESSING
  AWAITING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
}
